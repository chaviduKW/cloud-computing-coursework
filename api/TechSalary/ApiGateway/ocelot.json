        { "Host": "localhost", "Port": 5154 }
      ],
      "DownstreamPathTemplate": "/api/salaries"
    },

    {
      "UpstreamPathTemplate": "/api/salaries/pending",
      "UpstreamHttpMethod": [ "GET" ],

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5154 }
      ],
      "DownstreamPathTemplate": "/api/salaries/pending"
    },

    {
      "UpstreamPathTemplate": "/api/salaries/query",
      "UpstreamHttpMethod": [ "GET" ],

      "DownstreamScheme": "http",
