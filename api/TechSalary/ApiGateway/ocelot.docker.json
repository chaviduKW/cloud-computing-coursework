{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "identityapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "SwaggerKey": "identity"
    },
    {
      "DownstreamPathTemplate": "/swagger/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "identityapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/identity/swagger/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "identity"
    },
    {
      "DownstreamPathTemplate": "/api/salaries",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "salarysubmissionapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/salaries",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "salary"
    },
    {
      "DownstreamPathTemplate": "/api/salaries",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "salarysubmissionapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/salaries",
      "UpstreamHttpMethod": [ "POST" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RouteClaimsRequirement": {
        "http://schemas.microsoft.com/ws/2008/06/identity/claims/role": "Admin"
      },
      "SwaggerKey": "salary"
    },
    {
      "DownstreamPathTemplate": "/api/salaries/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "salarysubmissionapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/salaries/{id}",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "salary"
    },
    {
      "DownstreamPathTemplate": "/api/salaries/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "salarysubmissionapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/salaries/{id}",
      "UpstreamHttpMethod": [ "PUT", "DELETE" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RouteClaimsRequirement": {
        "http://schemas.microsoft.com/ws/2008/06/identity/claims/role": "Admin"
      },
      "SwaggerKey": "salary"
    },
    {
      "DownstreamPathTemplate": "/api/vote/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "voteapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/vote/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "SwaggerKey": "vote"
    },
    {
      "DownstreamPathTemplate": "/api/stats",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "statsapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/stats",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "stats"
    },
    {
      "DownstreamPathTemplate": "/api/search/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "searchapi",
          "Port": 80
        }
      ],
      "UpstreamPathTemplate": "/api/search/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "search"
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "identity",
      "Config": [
        {
          "Name": "Identity API",
          "Version": "v1",
          "Url": "http://identityapi:80/swagger/v1/swagger.json"
        }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000"
  }
}
