# Backend API target for the Vite dev-server proxy.
# Change this to point to wherever your API Gateway is running.
# Example for a remote server: API_TARGET=http://192.168.1.50:5000
API_TARGET=http://localhost:5000

# Optional: set this if you want the browser to call the API directly
# (bypasses the Vite proxy entirely, useful for production-like setups).
# VITE_API_BASE_URL=http://192.168.1.50:5000
